# PostgreSQL connection string (Supabase, Neon, etc.)
# For local development: use direct connection on port 5432
# For Vercel/Production: use transaction mode pooler on port 6543 with ?pgbouncer=true
DATABASE_URL="postgresql://postgres:password@db.xxxx.supabase.co:5432/postgres"

# Upstash Redis (for idempotency)
UPSTASH_REDIS_REST_URL="https://xxxx.upstash.io"
UPSTASH_REDIS_REST_TOKEN="xxxx"
